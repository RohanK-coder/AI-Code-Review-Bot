APP_NAME=Real-Time AI Code Review Bot
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

GITHUB_WEBHOOK_SECRET=replace_me
GITHUB_TOKEN=ghp_xxx_or_github_app_installation_token

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=code_review_memory
QDRANT_VECTOR_SIZE=3072

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/code_review_bot
MAX_DIFF_FILES=25
MAX_DIFF_CHARS_PER_FILE=12000
INLINE_COMMENT_FALLBACK_TO_PR_REVIEW=true
